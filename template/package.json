{
  "name": "my-app-tests",
  "version": "1.0.0",
  "description": "Playwright + TypeScript QA automation — generated by qa-starter-kit",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "auth": "playwright test setup/auth.setup.ts --headed",
    "typecheck": "tsc --noEmit",
    "scan": "ts-node --esm scripts/scan.ts",
    "rescan": "ts-node --esm scripts/rescan.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.14.0",
    "dotenv": "^16.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
