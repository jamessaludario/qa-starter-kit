# ════════════════════════════════════════════════════
# QA Automation Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ════════════════════════════════════════════════════

# ── Your App URLs ─────────────────────────────────────────────
# Main app URL (defaults to the built-in QA Academy Demo App)
BASE_URL=http://localhost:3000

# Admin panel URL (leave blank if same as BASE_URL)
ADMIN_BASE_URL=

# ── App Details ───────────────────────────────────────────────
# Name of your app — used in reports and prompts
APP_NAME=

# One-line description of what your app does
APP_DESCRIPTION=

# Comma-separated list of user roles in your app
# Examples: guest,user,admin  /  buyer,seller  /  viewer,editor
APP_ROLES=guest,user,admin

# ── App Source Code (optional) ────────────────────────────────
# Full local path to your app's source code
# Leave blank to skip codebase scanning
# Windows: C:\Users\you\projects\my-app
# Mac/Linux: /Users/you/projects/my-app
APP_REPO_PATH=

# ── Test Account Emails ───────────────────────────────────────
# Email addresses used when logging in manually to create auth sessions
# No passwords stored here — auth sessions are saved to auth/
USER_EMAIL=
ADMIN_EMAIL=

# ── Auth Sessions (auto-generated — do not edit) ──────────────
# These files are created by: npm run auth
# They are gitignored — never commit them
AUTH_USER_STATE=auth/user-state.json
AUTH_ADMIN_STATE=auth/admin-state.json
