# ════════════════════════════════════════════════════
# Scaffold Configuration
# Used by: npm run scaffold
# This configures the NEW project that scaffold creates.
# The starter kit itself is never modified.
# ════════════════════════════════════════════════════

# ── Project Name ──────────────────────────────────────────────
# Your app name — used to name the new project folder.
# Example: my-app → creates folder: ../my-app-tests
PROJECT_NAME=my-app

# ── Your App URLs ─────────────────────────────────────────────
# Main app URL (defaults to the built-in QA Academy Demo App)
BASE_URL=http://localhost:3000

# Admin panel URL (leave blank if same as BASE_URL)
ADMIN_BASE_URL=

# ── App Details ───────────────────────────────────────────────
# One-line description of your app (used in prompts)
APP_DESCRIPTION=

# Comma-separated list of user roles in your app
# Examples: guest,user,admin  /  buyer,seller  /  viewer,editor
APP_ROLES=guest,user,admin

# ── Your AI Agent ─────────────────────────────────────────────
# Which agent will you use? (affects which config folder is copied)
# Options: claude-code / cursor / copilot / windsurf / antigravity / other
PREFERRED_AGENT=claude-code
