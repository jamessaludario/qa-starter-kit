{
  "name": "qa-starter-kit",
  "version": "1.0.0",
  "description": "QA Automation Starter Kit — generate Playwright tests for any web app using AI agents",
  "private": true,
  "scripts": {
    "scaffold": "ts-node --esm scripts/scaffold.ts",
    "scan": "ts-node --esm scripts/scan.ts",
    "rescan": "ts-node --esm scripts/rescan.ts",
    "demo": "ts-node --esm scripts/demo-server.ts",
    "tour": "ts-node learn/tour.ts",
    "learn": "ts-node learn/tour.ts",
    "learn:sample": "playwright test --config learn/playwright.config.ts sample.todo.spec.ts",
    "learn:lessons": "playwright test --config learn/playwright.config.ts lessons",
    "learn:report": "playwright show-report learn/playwright-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.14.0",
    "dotenv": "^16.4.5",
    "fs-extra": "^11.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
